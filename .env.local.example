# Copy this file to .env.local and fill in values as needed.

# "mainnet" (default) targets Robinhood Chain (4663).
# "testnet" targets Robinhood Chain Testnet (46630).
NEXT_PUBLIC_CHAIN_ENV=mainnet

# Get a free project ID at https://cloud.walletconnect.com to enable the
# WalletConnect connector. Leave blank to omit WalletConnect from the
# connect flow — injected wallets (MetaMask/Rabby/Robinhood Wallet/etc.)
# work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Treasury wallet that live-pool contributions are sent to on Robinhood
# Chain until per-pool contracts are deployed. Optional — overrides the
# default committed in lib/chains.js.
NEXT_PUBLIC_POOL_TREASURY_ADDRESS=

# Oasis token contract address shown across the site. Optional — overrides
# the default committed in lib/chains.js.
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=
